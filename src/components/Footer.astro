---
const serviceLinks = ["Roller Replacement And Frame Repair", "Lock Repair", "Hinge Repair/Replacement", "Commercial Door Installation", "Commercial Door Repair", "Commercial Door Lock Services"];
const locations = ["Pocket Door Services Orlando", "Pocket Door Services Miami", "Pocket Door Services Fort Myers"];
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <img src="/images/logo-white.png" alt="Pocket Door Services" class="h-14 w-auto mb-4" />
        <p class="text-gray-300 text-sm leading-relaxed">Specialize in the installation, repair, and maintenance of pocket doors. These services ensure smooth operation and functionality of pocket doors, which slide into a compartment within the wall, saving space and providing a sleek, modern look.</p>
      </div>
      <div>
        <h4 class="font-heading text-xl tracking-wide mb-4">Information</h4>
        <div class="space-y-2 text-gray-300 text-sm">
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:9547275410" class="hover:text-white">954-727-5410</a>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Open 24 Hours
          </p>
        </div>
      </div>
      <div>
        <h4 class="font-heading text-xl tracking-wide mb-4">Services</h4>
        <ul class="space-y-1">
          {serviceLinks.map((s) => (
            <li><a href="/#services" class="text-gray-300 text-sm hover:text-white transition-colors">{s}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-xl tracking-wide mb-4">Locations</h4>
        <ul class="space-y-1">
          {locations.map((l) => (
            <li><a href="#" class="text-gray-300 text-sm hover:text-white transition-colors">{l}</a></li>
          ))}
        </ul>
        <h4 class="font-heading text-xl tracking-wide mb-3 mt-6">Pages</h4>
        <ul class="space-y-1">
          <li><a href="/" class="text-gray-300 text-sm hover:text-white">Home</a></li>
          <li><a href="/about-us" class="text-gray-300 text-sm hover:text-white">About Us</a></li>
          <li><a href="/contact" class="text-gray-300 text-sm hover:text-white">Contact</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t border-gray-600">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <p class="text-gray-400 text-sm text-center">&copy; Copyright 2024. Pocket Door Services. All Rights Reserved.</p>
    </div>
  </div>
</footer>
