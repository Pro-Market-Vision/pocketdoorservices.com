---
const serviceLinks = [
  { name: "Roller Replacement & Frame Repair", href: "/service/roller-replacement-and-frame-repair" },
  { name: "Lock Repair", href: "/service/lock-repair" },
  { name: "Hinge Repair/Replacement", href: "/service/hinge-repair-replacement" },
  { name: "Commercial Door Installation", href: "/service/commercial-door-installation" },
  { name: "Commercial Door Repair", href: "/service/commercial-door-repair" },
  { name: "Commercial Door Lock Services", href: "/service/commercial-door-lock-services" },
];
const locations = [
  { name: "Pocket Door Services Orlando", href: "/location/pocket-door-services-orlando" },
  { name: "Pocket Door Services Fort Myers", href: "/location/fort-myers" },
  { name: "Pocket Door Services Miami", href: "/location/pocket-door-services-miami" },
];
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary text-white">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <a href="/" class="flex items-center gap-2 mb-4" aria-label="Pocket Door Services homepage">
          <img src="/images/logo copy.png" alt="Pocket Door Services logo" class="h-20 w-auto brightness-0 invert" />
          <div class="flex flex-col justify-center leading-tight">
            <span class="font-heading text-xl tracking-wide text-white leading-none">POCKET &</span>
            <span class="font-heading text-xl tracking-wide text-white leading-none">COMMERCIAL</span>
            <span class="font-heading text-xl tracking-wide text-white leading-none">DOOR SERVICES</span>
          </div>
        </a>
        <p class="text-gray-300 text-sm leading-relaxed">We specialize in the installation, repair, and maintenance of pocket doors in Orlando, Miami, and Fort Myers. Our expert technicians ensure smooth operation and functionality for your home or business.</p>
      </div>
      <div>
        <h3 class="font-heading text-xl tracking-wide mb-4">Contact Information</h3>
        <div class="space-y-2 text-gray-300 text-sm">
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:9547275410" class="hover:text-white" aria-label="Call Pocket Door Services">(954) 727-5410</a>
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            Open 24/7
          </p>
          <p class="flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            Serving Orlando, Miami & Fort Myers
          </p>
        </div>
      </div>
      <div>
        <h3 class="font-heading text-xl tracking-wide mb-4">Our Services</h3>
        <ul class="space-y-1">
          {serviceLinks.map((s) => (
            <li><a href={s.href} class="text-gray-300 text-sm hover:text-white transition-colors">{s.name}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="font-heading text-xl tracking-wide mb-4">Service Areas</h3>
        <ul class="space-y-1">
          {locations.map((l) => (
            <li><a href={l.href} class="text-gray-300 text-sm hover:text-white transition-colors">{l.name}</a></li>
          ))}
        </ul>
        <h3 class="font-heading text-xl tracking-wide mb-3 mt-6">Pages</h3>
        <ul class="space-y-1">
          <li><a href="/" class="text-gray-300 text-sm hover:text-white">Home</a></li>
          <li><a href="/about-us" class="text-gray-300 text-sm hover:text-white">About Us</a></li>
          <li><a href="/blog" class="text-gray-300 text-sm hover:text-white">Blog</a></li>
          <li><a href="/contact" class="text-gray-300 text-sm hover:text-white">Contact</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t border-gray-600">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-400 text-sm">&copy; {currentYear} Pocket Door Services. All Rights Reserved.</p>
      <div class="flex items-center gap-4">
        <!-- Google Business - Fort Myers -->
        <a href="https://maps.google.com/maps?cid=14237320329652946561" target="_blank" rel="noopener noreferrer" aria-label="Google Business Profile - Fort Myers" class="text-gray-400 hover:text-white transition-colors flex items-center gap-1">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
          <span class="text-xs">Fort Myers</span>
        </a>
        <!-- Google Business - Orlando -->
        <a href="https://maps.google.com/maps?cid=1347897679910126207" target="_blank" rel="noopener noreferrer" aria-label="Google Business Profile - Orlando" class="text-gray-400 hover:text-white transition-colors flex items-center gap-1">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" /><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" /><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" /><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" /></svg>
          <span class="text-xs">Orlando</span>
        </a>
        <!-- Add more social links here as accounts are created -->
      </div>
    </div>
  </div>
</footer>
