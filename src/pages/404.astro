---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Pocket Door Services"
  description="The page you're looking for doesn't exist. Contact Pocket Door Services for pocket door installation, repair & maintenance in Orlando, Miami & Fort Myers."
>

  <section class="relative bg-primary text-white py-16 md:py-20 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.png')" role="img" aria-label="Pocket Door Services"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/75 to-primary/50"></div>
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-7xl md:text-9xl tracking-wide mb-4">404</h1>
      <p class="text-xl md:text-2xl font-light text-gray-200">Page Not Found</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Looks Like This Door Doesn't Open</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        The page you're looking for may have been moved or doesn't exist. But we're still here to help with all your pocket door, sliding door, and commercial door needs across Florida.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12 max-w-3xl mx-auto">
        <a href="/" class="bg-primary text-white font-heading text-lg tracking-wide px-6 py-4 rounded hover:bg-primary/80 transition-colors text-center">HOME</a>
        <a href="/contact" class="bg-accent text-white font-heading text-lg tracking-wide px-6 py-4 rounded hover:bg-blue-600 transition-colors text-center">CONTACT US</a>
        <a href="tel:9547275410" class="bg-primary text-white font-heading text-lg tracking-wide px-6 py-4 rounded hover:bg-primary/80 transition-colors text-center">CALL NOW</a>
      </div>

      <h3 class="font-heading text-2xl tracking-wide text-primary mb-6">Our Services</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-3xl mx-auto">
        <a href="/service/roller-replacement-and-frame-repair" class="text-accent hover:underline text-sm">Roller Replacement & Frame Repair</a>
        <a href="/service/lock-repair" class="text-accent hover:underline text-sm">Lock Repair</a>
        <a href="/service/hinge-repair-replacement" class="text-accent hover:underline text-sm">Hinge Repair & Replacement</a>
        <a href="/service/commercial-door-installation" class="text-accent hover:underline text-sm">Commercial Door Installation</a>
        <a href="/service/commercial-door-repair" class="text-accent hover:underline text-sm">Commercial Door Repair</a>
        <a href="/service/commercial-door-lock-services" class="text-accent hover:underline text-sm">Commercial Door Lock Services</a>
      </div>

      <h3 class="font-heading text-2xl tracking-wide text-primary mt-8 mb-6">Service Areas</h3>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/location/pocket-door-services-orlando" class="text-accent hover:underline">Orlando</a>
        <span class="text-gray-300">|</span>
        <a href="/location/fort-myers" class="text-accent hover:underline">Fort Myers</a>
        <span class="text-gray-300">|</span>
        <a href="/location/pocket-door-services-miami" class="text-accent hover:underline">Miami</a>
      </div>

      <div class="mt-12 text-gray-500 text-sm">
        <p>Available 24/7 · <a href="tel:9547275410" class="text-accent hover:underline">(954) 727-5410</a></p>
      </div>
    </div>
  </section>

</Layout>
