---
import Layout from '../../layouts/Layout.astro';

const services = [
  { name: "Roller Replacement And Frame Repair", slug: "roller-replacement-and-frame-repair", description: "Fort Myers humidity and settling foundations take a toll on rollers and frames. We replace with weather-rated hardware and realign for smooth, lasting operation." },
  { name: "Lock Repair", slug: "lock-repair", description: "Humidity-related swelling is the top cause of pocket door lock failure in Fort Myers. We repair and upgrade with moisture-resistant hardware." },
  { name: "Hinge Repair/Replacement", slug: "hinge-repair-replacement", description: "Foundation settling in Southwest Florida stresses door hinges over time. We find and fix the root cause, not just the symptom." },
  { name: "Commercial Door Installation", slug: "commercial-door-installation", description: "From US-41 retail to Fort Myers medical offices, we install commercial pocket doors built for Southwest Florida's climate and traffic demands." },
  { name: "Commercial Door Repair", slug: "commercial-door-repair", description: "Fast commercial pocket door repair across Lee County. Same-day service with parts on the truck — because your business can't wait." },
  { name: "Commercial Door Lock Services", slug: "commercial-door-lock-services", description: "Commercial pocket door lock installation, repair, and rekeying for Fort Myers businesses. Hardware chosen for durability in Southwest Florida's environment." },
];
---

<Layout
  title="Pocket Door Services Fort Myers | Installation, Repair & Maintenance"
  description="Fort Myers' trusted pocket door specialists. Expert installation, repair & maintenance for homes and businesses across Southwest Florida. 24/7 emergency. Call (239) 243-0906."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-6 md:py-8 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.png')" role="img" aria-label="Pocket door installation service in Fort Myers, FL"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/75 to-primary/50"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Pocket Door Installation & Repair in Fort Myers</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Southwest Florida's Pocket Door Specialists</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          From waterfront homes on Sanibel and Cape Coral to commercial spaces along US-41, pocket doors are gaining popularity across Southwest Florida for their space-saving design and clean aesthetics. Our Fort Myers team brings specialized pocket door expertise to every job — the right hardware, proper installation techniques, and the attention to detail that keeps your doors gliding for years.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:2392430906" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors text-center" aria-label="Call Pocket Door Services Fort Myers">
            (239) 243-0906
          </a>
          <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center">
            FREE ESTIMATE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Why Fort Myers Homeowners Are Choosing Pocket Doors</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Southwest Florida's lifestyle revolves around open, airy living spaces — and pocket doors deliver exactly that. They create seamless transitions between indoor and outdoor areas, open up tight hallways in older Cape Coral homes, and add a modern touch to bathroom and closet renovations in Fort Myers Beach condos. Unlike barn doors, they don't take up wall space. Unlike bifold doors, they don't rattle or jam.
        </p>
        <p class="text-gray-600 leading-relaxed">
          But Fort Myers has its own installation challenges. Older block construction requires different anchoring than newer frame-built homes. Florida's humidity demands corrosion-resistant hardware. And the sandy soil in parts of Lee County can cause foundation settling that throws pocket door frames out of alignment over time. We factor all of this into every installation, which is why our doors stay straight and glide smoothly long after the job is done.
        </p>
      </div>
      <div>
        <img src="/images/pocket door.webp" alt="Pocket door installation by expert technician in Fort Myers" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Google Reviews + Emergency CTA -->
  <section class="py-16 bg-primary text-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="rounded-lg overflow-hidden shadow-lg">
        <iframe src="https://www.google.com/maps?cid=14237320329652946561&output=embed" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Pocket Door Services Fort Myers Google Reviews"></iframe>
      </div>
      <div class="text-center lg:text-left">
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">24/7 Emergency Service in Fort Myers</h2>
        <p class="text-gray-300 leading-relaxed mb-4">See what our Fort Myers customers are saying about us on Google — then call us when you need us.</p>
        <p class="text-gray-300 leading-relaxed mb-8">
          Pocket door stuck or jammed? Our emergency team covers all of Lee County — Fort Myers, Cape Coral, Bonita Springs, Estero, and Sanibel Island. We respond 24/7 with fully stocked trucks for single-visit repairs.
        </p>
        <a href="tel:2392430906" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (239) 243-0906</a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our Pocket Door Services in Fort Myers</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30 block">
            <div class="p-6">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="text-accent font-heading tracking-wide group-hover:underline">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Pocket Door Estimate</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Whether you're renovating a waterfront home on Cape Coral or outfitting a commercial space in Fort Myers, we'd love to hear about your project. Call us or fill out the form for a free, no-obligation estimate.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:2392430906" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call (239) 243-0906</a>
        <a href="/contact" class="bg-primary text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-dark transition-colors">Request Free Estimate</a>
      </div>
    </div>
  </section>

</Layout>
