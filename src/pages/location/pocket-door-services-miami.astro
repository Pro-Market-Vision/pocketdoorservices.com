---
import Layout from '../../layouts/Layout.astro';

const services = [
  { name: "Roller Replacement And Frame Repair", slug: "roller-replacement-and-frame-repair", description: "Salt air and humidity destroy standard rollers fast. We install marine-grade, corrosion-resistant replacements built for South Florida's coastal conditions." },
  { name: "Lock Repair", slug: "lock-repair", description: "Miami's humidity causes pocket door panels to swell, putting extra stress on lock mechanisms. We repair with hardware designed for coastal environments." },
  { name: "Hinge Repair/Replacement", slug: "hinge-repair-replacement", description: "Corrosion from salt air is the leading cause of hinge failure in Miami properties. We replace with stainless steel hardware rated for coastal use." },
  { name: "Commercial Door Installation", slug: "commercial-door-installation", description: "From Brickell offices to Wynwood retail, we install commercial pocket doors engineered for Miami's climate and high-traffic commercial environments." },
  { name: "Commercial Door Repair", slug: "commercial-door-repair", description: "Miami's commercial pocket doors face salt air corrosion and heavy traffic. We repair and upgrade with hardware that withstands South Florida's conditions." },
  { name: "Commercial Door Lock Services", slug: "commercial-door-lock-services", description: "Commercial lock installation, repair, and rekeying for Miami businesses — with hardware that resists the corrosion South Florida's climate causes." },
];
---

<Layout
  title="Pocket Door Services Miami | Installation, Repair & Replacement"
  description="Miami's pocket door experts. Installation, repair & replacement for residential and commercial properties across South Florida. Humidity-rated hardware. 24/7 emergency. Call (954) 727-5410."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-6 md:py-8 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.png')" role="img" aria-label="Pocket door installation service in Miami, FL"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/75 to-primary/50"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Pocket Door Services in Miami & South Florida</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Pocket Door Experts for Miami's Homes & Businesses</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          Miami's modern architecture and space-conscious design make pocket doors a natural fit — from Brickell high-rises to Coral Gables estates to South Beach commercial spaces. Our South Florida team handles pocket door installation, repair, and replacement with hardware and techniques built for Miami's salt air, humidity, and high-traffic environments.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:9547275410" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors text-center" aria-label="Call Pocket Door Services Miami">
            (954) 727-5410
          </a>
          <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center">
            FREE ESTIMATE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Pocket Doors Built for Miami's Climate and Style</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Miami's coastal environment is tough on door hardware. Salt air corrodes standard rollers and tracks. Humidity causes wood panels to swell, throwing off alignment and making doors stick. UV exposure through glass pocket doors degrades seals and finishes. These aren't problems you'll face in other markets — and they're not problems a general contractor is thinking about when they install your pocket door.
        </p>
        <p class="text-gray-600 leading-relaxed">
          We specify corrosion-resistant stainless steel rollers, marine-grade track hardware, and moisture-sealed framing for every Miami installation. For existing pocket doors showing signs of humidity damage — sticking, swelling, corroded hardware — we repair and upgrade with materials that hold up year after year in South Florida's climate. It costs a little more upfront, but it eliminates the cycle of repairs that comes with using standard hardware in a coastal environment.
        </p>
      </div>
      <div>
        <img src="/images/pocket door 2.webp" alt="Pocket door repair service by expert technician in Miami" class="rounded-lg shadow-lg w-3/4 mx-auto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our Pocket Door Services in Miami</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30 block">
            <div class="p-6">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="text-accent font-heading tracking-wide group-hover:underline">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">24/7 Pocket Door Emergency Services in Miami</h2>
      <p class="text-gray-300 leading-relaxed mb-8">
        Pocket door emergency in Miami? Whether you're in Brickell, Coral Gables, Miami Beach, or Kendall, our team responds 24/7. We carry corrosion-resistant parts on every truck because in South Florida, standard hardware isn't good enough.
      </p>
      <a href="tel:9547275410" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (954) 727-5410</a>
    </div>
  </section>

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Pocket Door Estimate</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Whether you're installing pocket doors in a new Miami condo or repairing a stuck door in a Coral Gables home, we're ready to help. Request your free estimate and find out why Miami homeowners and businesses trust us with their pocket doors.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275410" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call (954) 727-5410</a>
        <a href="/contact" class="bg-primary text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-dark transition-colors">Request Free Estimate</a>
      </div>
    </div>
  </section>

</Layout>
