---
import Layout from '../../layouts/Layout.astro';

const services = [
  { name: "Roller Replacement And Frame Repair", slug: "roller-replacement-and-frame-repair", description: "Orlando's humidity accelerates roller corrosion. We replace with corrosion-resistant, weight-matched hardware built for Florida conditions." },
  { name: "Lock Repair", slug: "lock-repair", description: "Pocket door locks in Orlando homes take extra stress from humidity-related swelling. We repair and replace with hardware designed to perform in Florida's climate." },
  { name: "Hinge Repair/Replacement", slug: "hinge-repair-replacement", description: "Settling foundations and block construction in older Orlando homes cause hinge stress. We diagnose the root cause and fix it permanently." },
  { name: "Commercial Door Installation", slug: "commercial-door-installation", description: "From International Drive retail to Orlando Health medical offices, we install commercial pocket doors built for Central Florida's high-traffic environments." },
  { name: "Commercial Door Repair", slug: "commercial-door-repair", description: "Orlando businesses can't afford downtime. We offer same-day commercial pocket door repair with fully stocked trucks across the metro area." },
  { name: "Commercial Door Lock Services", slug: "commercial-door-lock-services", description: "Keyed entry, privacy locks, and master key systems for Orlando's commercial spaces — installed and serviced by pocket door specialists." },
];
---

<Layout
  title="Pocket Door Services Orlando | Installation, Repair & Emergency Service"
  description="Orlando's trusted pocket door specialists. Expert installation, repair & roller replacement for homes and businesses across Central Florida. 24/7 emergency service. Call (407) 557-8893."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-6 md:py-8 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/hero.png')" role="img" aria-label="Pocket door installation service in Orlando, FL"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/75 to-primary/50"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Pocket Door Installation & Repair in Orlando</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Central Florida's Dedicated Pocket Door Specialists</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          From Winter Park renovations to downtown Orlando commercial build-outs, pocket doors are becoming the go-to solution for Florida homeowners and businesses looking to maximize space without sacrificing style. Our Orlando team specializes in pocket door, sliding door, and commercial door installation, repair, and replacement — bringing the right tools, the right parts, and years of focused experience to every job across Central Florida.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:4075578893" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors text-center" aria-label="Call Pocket Door Services Orlando">
            (407) 557-8893
          </a>
          <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center">
            FREE ESTIMATE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Why Orlando Properties Are Switching to Pocket Doors</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Orlando's real estate market rewards efficient use of space. Whether it's a condo near Lake Eola, a family home in Dr. Phillips, or a medical office on Sand Lake Road, pocket doors recover 10-15 square feet per opening that swing doors waste. In a market where every square foot counts, that adds up fast — especially in multi-room renovations.
        </p>
        <p class="text-gray-600 leading-relaxed">
          But pocket doors only deliver that value when they're installed correctly. Orlando's unique building conditions — concrete block construction in older homes, newer lightweight framing in rapidly built subdivisions, and Florida's relentless humidity — all affect how a pocket door system should be specified and installed. We account for these factors on every job, choosing hardware and techniques matched to your specific structure. That's the kind of local expertise you don't get from a national franchise or a general handyman.
        </p>
      </div>
      <div>
        <img src="/images/simple pocket door.jpg" alt="Pocket door installation by expert technician in Orlando" class="rounded-lg shadow-lg w-3/4 mx-auto" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Google Reviews + Emergency CTA -->
  <section class="py-16 bg-primary text-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="rounded-lg overflow-hidden shadow-lg">
        <iframe src="https://www.google.com/maps?cid=1347897679910126207&output=embed" width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Pocket Door Services Orlando Google Reviews"></iframe>
      </div>
      <div class="text-center lg:text-left">
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">24/7 Emergency Service in Orlando</h2>
        <p class="text-gray-300 leading-relaxed mb-4">See what our Orlando customers are saying about us on Google — then call us when you need us.</p>
        <p class="text-gray-300 leading-relaxed mb-8">
          Pocket door stuck in the wall? Lock jammed? Track derailed? Our Orlando emergency team responds 24/7 across Orange, Seminole, and Osceola counties. We arrive with a full parts inventory, so most emergency repairs are finished in a single visit.
        </p>
        <a href="tel:4075578893" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (407) 557-8893</a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our Pocket Door Services in Orlando</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30 block">
            <div class="p-6">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="text-accent font-heading tracking-wide group-hover:underline">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Pocket Door Estimate</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Planning a pocket door installation for your Orlando home or business? Have a door that needs repair? Tell us about your project and we'll provide a detailed estimate at no cost. Our Orlando team is ready to help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:4075578893" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call (407) 557-8893</a>
        <a href="/contact" class="bg-primary text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-dark transition-colors">Request Free Estimate</a>
      </div>
    </div>
  </section>

</Layout>
