---
import Layout from '../../layouts/Layout.astro';

const services = [
  { name: "Roller Replacement And Frame Repair", slug: "roller-replacement-and-frame-repair", description: "Expert roller replacement and frame repair to restore smooth pocket door operation and structural integrity." },
  { name: "Lock Repair", slug: "lock-repair", description: "Professional lock repair services to ensure your pocket doors provide reliable security and functionality." },
  { name: "Hinge Repair/Replacement", slug: "hinge-repair-replacement", description: "Comprehensive hinge repair and replacement to eliminate squeaking, misalignment, and breakage issues." },
  { name: "Commercial Door Installation", slug: "commercial-door-installation", description: "Professional pocket door installation for commercial spaces, designed for durability and high-traffic use." },
  { name: "Commercial Door Repair", slug: "commercial-door-repair", description: "Fast, reliable commercial pocket door repair to minimize downtime and restore full functionality." },
  { name: "Commercial Door Lock Services", slug: "commercial-door-lock-services", description: "Complete commercial lock services including installation, repair, and maintenance of locking systems." },
];
---

<Layout
  title="Pocket Door Services Orlando | Installation & Repair"
  description="Professional pocket door installation, repair & maintenance in Orlando, FL. Sliding doors that save space and provide a modern aesthetic. 24/7 emergency service. Call (407) 557-8893."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/services/hero.webp')" role="img" aria-label="Pocket door installation service in Orlando, FL"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/95 to-primary/70"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Professional Pocket Door Services in Orlando</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Serving Orlando & Central Florida</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          We specialize in the installation, repair, and maintenance of pocket doors — sliding doors that retract into wall compartments to save space and provide a modern aesthetic. Our Orlando team delivers quality workmanship with transparent pricing for every project.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="tel:4075578893" class="bg-white text-primary font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-gray-100 transition-colors text-center" aria-label="Call Pocket Door Services Orlando">
            (407) 557-8893
          </a>
          <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center">
            FREE ESTIMATE
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Expert Solutions for Your Orlando Property</h2>
        <p class="text-gray-600 leading-relaxed mb-6">
          Whether you are upgrading your home or enhancing a commercial space, our Orlando pocket door specialists deliver expert installation, repair, and maintenance services tailored to your needs. Pocket doors are an excellent choice for maximizing space and adding a sleek, modern look to any room.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Our experienced technicians handle everything from new pocket door installations to emergency repairs, ensuring your doors operate smoothly and efficiently. We are committed to quality workmanship, transparent pricing, and complete customer satisfaction on every project in the Orlando area.
        </p>
      </div>
      <div>
        <img src="/images/services/about.webp" alt="Pocket door installation by expert technician in Orlando" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-gray-light" id="services">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our Pocket Door Services in Orlando</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((s) => (
          <a href={`/service/${s.slug}`} class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-border/30 block">
            <div class="p-6">
              <h3 class="font-heading text-2xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">{s.name}</h3>
              <p class="text-gray-600 text-sm leading-relaxed mb-4">{s.description}</p>
              <span class="text-accent font-heading tracking-wide group-hover:underline">Learn More &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Emergency CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">24/7 Pocket Door Emergency Services in Orlando</h2>
      <p class="text-gray-300 leading-relaxed mb-8">
        Need urgent pocket door repair in Orlando? Our technicians are available around the clock to address emergency repairs and get your doors back on track quickly. Quality workmanship and transparent pricing guaranteed.
      </p>
      <a href="tel:4075578893" class="inline-flex bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call Now (407) 557-8893</a>
    </div>
  </section>

  <!-- Estimate -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Get Your Free Pocket Door Estimate</h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Transform your Orlando space with the convenience and elegance of pocket doors. Contact us today for a free consultation and discover how our services can enhance your home or business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:4075578893" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-blue-700 transition-colors">Call (407) 557-8893</a>
        <a href="/contact" class="bg-primary text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-dark transition-colors">Request Free Estimate</a>
      </div>
    </div>
  </section>

</Layout>
